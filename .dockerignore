# Keep local environments, secrets, caches, and logs out of the container build context.
.git/
.venv/
__pycache__/
_pycache_/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyc
*.pyo
*.pyd
*.log
backend/.env
backend/.env.*
!backend/.env.example
service-account*.json
gcp-key*.json
backend/.run-*.log
frontend/.run-*.log